# Public URLs (store-friendly)
EXPO_PUBLIC_PRIVACY_URL=https://YOUR_DOMAIN/privacy
EXPO_PUBLIC_TERMS_URL=https://YOUR_DOMAIN/terms
EXPO_PUBLIC_PUBLIC_APP_URL=https://YOUR_DOMAIN/app
EXPO_PUBLIC_PUBLIC_INVITE_URL_BASE=https://YOUR_DOMAIN/invite

# Sentry (optional)
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENV=prod
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0

# RevenueCat (required for Pro subscriptions)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT=pro
EXPO_PUBLIC_REVENUECAT_OFFERING=default

# Flags
EXPO_PUBLIC_STORE_BUILD=true
EXPO_PUBLIC_LOW_END_MODE=false
EXPO_PUBLIC_USE_SKIA_OVERLAY=true
