{
  "version": "1.0.0",
  "goal": "fair, stable, repeatable scoring for singing drills",
  "frame_inputs": {
    "required_fields": [
      "timestamp_ms",
      "observed_hz",
      "smoothed_hz",
      "target_hz",
      "voiced",
      "rms",
      "pitch_confidence",
      "is_reference_playback",
      "is_recovery_state"
    ],
    "preprocessing": [
      "median filter on raw pitch frames",
      "note hysteresis to reduce note flicker",
      "spike rejection for one-frame jumps",
      "VAD plus confidence gating before scoring"
    ]
  },
  "pitch_math": {
    "hz_to_midi": "69 + 12 * log2(hz / 440)",
    "cents_error": "1200 * log2(observed_hz / target_hz)",
    "abs_cents_error": "abs(cents_error)",
    "tuning_bands": {
      "perfect": 15,
      "good": 25,
      "ok": 40,
      "poor": 60
    },
    "smooth_frame_accuracy": "clamp(1 - (abs_error / 60)^1.35, 0, 1)"
  },
  "shared_metrics": {
    "stability_stddev_cents": "stddev(cents_error over voiced valid frames in analysis window)",
    "voiced_ratio": "voiced_frames / expected_active_frames",
    "confidence_score": "clamp((mean_confidence - 0.45) / 0.5, 0, 1)",
    "dynamic_curve_smoothness": "1 - normalized absolute deviation from target amplitude envelope",
    "repeatability_score": "1 - min(score_stddev_last_3 / 18, 1)"
  },
  "confidence_caps": [
    {
      "when": "mean_confidence < 0.45",
      "max_final_score": 59
    },
    {
      "when": "mean_confidence < 0.35",
      "max_final_score": 45
    }
  ],
  "drill_family_formulas": {
    "match_note": {
      "components": {
        "accuracy": "average(frame_accuracy)",
        "zone": "time_in_good_zone_ms / active_time_ms",
        "entry": "clamp(1 - entry_time_seconds / 2.5, 0, 1)",
        "overshoot": "clamp(1 - overshoot_events / 3, 0, 1)",
        "voiced": "voiced_score"
      },
      "formula": "0.40*accuracy + 0.25*zone + 0.15*entry + 0.10*overshoot + 0.10*voiced"
    },
    "sustain_hold": {
      "components": {
        "accuracy": "average(frame_accuracy)",
        "stability": "clamp(1 - stability_stddev_cents / 35, 0, 1)",
        "hold": "clamp(held_duration_ms / target_hold_ms, 0, 1)",
        "zone": "time_in_good_zone_ms / target_hold_ms",
        "voiced": "voiced_score"
      },
      "formula": "0.25*accuracy + 0.30*stability + 0.25*hold + 0.10*zone + 0.10*voiced"
    },
    "pitch_slide": {
      "components": {
        "entry": "clamp(1 - entry_time_ms / target_entry_limit_ms, 0, 1)",
        "hold": "clamp(hold_after_entry_ms / required_hold_ms, 0, 1)",
        "direction": "1 if correct_direction else 0",
        "smoothness": "clamp(1 - slide_jerk_index / 0.8, 0, 1)",
        "end_accuracy": "final_frame_accuracy"
      },
      "formula": "0.30*entry + 0.25*hold + 0.20*direction + 0.15*smoothness + 0.10*end_accuracy"
    },
    "interval_jump": {
      "components": {
        "note1": "avg_accuracy_target1",
        "note2": "avg_accuracy_target2",
        "interval_size": "clamp(1 - abs(interval_size_error_semitones) / 2, 0, 1)",
        "direction": "1 if correct_direction else 0",
        "stability": "stability_score_target2"
      },
      "formula": "0.20*note1 + 0.25*note2 + 0.25*interval_size + 0.15*direction + 0.15*stability"
    },
    "melody_echo": {
      "components": {
        "contour": "correct_contour_transitions / total_transitions",
        "interval": "mean(clamp(1 - abs(interval_error_semitones)/2, 0, 1))",
        "note": "mean(per_note_accuracy)",
        "rhythm": "clamp(1 - avg_onset_error_ms / 350, 0, 1)",
        "completion": "sung_notes / expected_notes"
      },
      "formula": "0.30*contour + 0.25*interval + 0.20*note + 0.15*rhythm + 0.10*completion"
    },
    "phrase_sing": {
      "components": {
        "pitch": "avg_accuracy",
        "continuity": "phrase_completion_ratio",
        "dynamic": "dynamic_range_match",
        "breath": "clamp(1 - bad_breath_breaks / allowed_breaks, 0, 1)",
        "consistency": "clamp(1 - score_stddev_last3 / 18, 0, 1)"
      },
      "formula": "0.35*pitch + 0.20*continuity + 0.15*dynamic + 0.10*breath + 0.20*consistency"
    },
    "dynamic_control": {
      "components": {
        "curve": "dynamic_curve_smoothness",
        "range": "dynamic_range_match",
        "pitch": "avg_accuracy",
        "completion": "completion_ratio",
        "voiced": "voiced_score"
      },
      "formula": "0.30*curve + 0.20*range + 0.20*pitch + 0.15*completion + 0.15*voiced"
    },
    "vowel_shape": {
      "components": {
        "vowel": "vowel_consistency_score",
        "pitch": "avg_accuracy",
        "legato": "legato_score",
        "completion": "completion_ratio",
        "confidence": "confidence_score"
      },
      "formula": "0.35*vowel + 0.20*pitch + 0.20*legato + 0.10*completion + 0.15*confidence"
    },
    "register_bridge": {
      "components": {
        "continuity": "bridge_continuity_score",
        "pitch": "avg_accuracy",
        "crack_avoidance": "clamp(1 - bridge_crack_events/2, 0, 1)",
        "vowel": "vowel_consistency_score",
        "completion": "completion_ratio"
      },
      "formula": "0.30*continuity + 0.20*pitch + 0.20*crack_avoidance + 0.15*vowel + 0.15*completion"
    },
    "performance_run": {
      "components": {
        "pitch": "avg_accuracy",
        "continuity": "phrase_completion_ratio",
        "dynamic": "dynamic_range_match",
        "consistency": "repeatability_score",
        "expression": "expression_proxy_score"
      },
      "formula": "0.25*pitch + 0.20*continuity + 0.15*dynamic + 0.20*consistency + 0.20*expression"
    },
    "confidence_rep": {
      "components": {
        "completion": "completion_ratio",
        "non_abort": "1 if abort_flag=false else 0",
        "voiced": "voiced_score",
        "accuracy": "avg_accuracy",
        "confidence": "confidence_score"
      },
      "formula": "0.35*completion + 0.25*non_abort + 0.15*voiced + 0.10*accuracy + 0.15*confidence"
    }
  },
  "fairness_tuning": {
    "grace_windows_ms": {
      "match_note": 450,
      "sustain_hold": 350,
      "pitch_slide": 500,
      "interval_jump": 450,
      "melody_echo": 500,
      "phrase_sing": 600,
      "performance_run": 700
    },
    "best_window_scoring": [
      "for beginner match_note and sustain_hold, score best valid window rather than entire take",
      "clip top and bottom 5 percent of cents errors in long drills before averaging"
    ],
    "hard_fail_caps": [
      "if direction wrong and interval size error > 2 semitones, cap interval drill at 49",
      "if held duration < 50 percent of target on sustain_hold, cap at 64",
      "if voiced_ratio < 0.40 on sustain_hold, cap at 54"
    ],
    "repeatability_targets": {
      "same_audio_rescored_10x_score_stddev_max": 2.5,
      "same_audio_rescored_10x_spread_max": 6
    }
  },
  "sample_result_object": {
    "attempt_id": "att_001",
    "drill_id": "D001",
    "final_score": 78,
    "passed": true,
    "band": "pass",
    "components": {
      "accuracy": 0.76,
      "stability": 0.81,
      "completion": 0.74,
      "voiced": 0.88
    },
    "metrics": {
      "mean_abs_cents": 18.4,
      "time_in_good_zone_ms": 2430,
      "held_duration_ms": 2910,
      "stability_stddev_cents": 11.2,
      "voiced_ratio": 0.84,
      "mean_confidence": 0.91
    },
    "diagnosis_tags": [
      "slight_flat_bias",
      "good_stability"
    ],
    "coach_tip": "You stayed steady. Next, aim a tiny bit higher on entry.",
    "next_recommended_drill_id": "D002",
    "help_mode_applied": false
  }
}