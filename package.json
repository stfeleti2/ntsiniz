{
  "name": "ntsiniz",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0 <25",
    "npm": ">=10"
  },
  "main": "index.js",
  "scripts": {
    "start": "npx expo start",
    "dev": "npx expo start --dev-client",
    "storybook": "EXPO_PUBLIC_STORYBOOK_ENABLED=true EXPO_PUBLIC_STORYBOOK_ROOT=true npx expo start --dev-client",
    "storybook:ios": "EXPO_PUBLIC_STORYBOOK_ENABLED=true EXPO_PUBLIC_STORYBOOK_ROOT=true npx expo start --dev-client --ios",
    "storybook:android": "EXPO_PUBLIC_STORYBOOK_ENABLED=true EXPO_PUBLIC_STORYBOOK_ROOT=true npx expo start --dev-client --android",
    "storybook:web": "storybook dev -p 6006",
    "storybook:web:build": "storybook build",
    "android": "npx expo run:android",
    "ios": "watchman watch-del \"$PWD\" >/dev/null 2>&1 || true; watchman watch-project \"$PWD\" >/dev/null 2>&1 || true; unset NO_COLOR; npx expo run:ios",
    "prebuild": "npx expo prebuild",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:core": "node --test dist-core/tests/*.test.js",
    "build:core": "tsc -p tsconfig.core.json",
    "test": "npm run build:core && npm run test:core && npm run test:ui",
    "e2e:maestro": "maestro test maestro",
    "e2e:detox:build:ios": "detox build -c ios.sim.debug",
    "e2e:detox:test:ios": "detox test -c ios.sim.debug",
    "e2e:detox:build:android": "detox build -c android.emu.debug",
    "e2e:detox:test:android": "detox test -c android.emu.debug",
    "ci:fast": "npm run lint && npm run typecheck && npm run check:i18n && npm run check:telemetry && npm run check:telemetry-pii && npm run check:locale-formatting && npm run check:lockfile && npm run check:no-todo-core && npm run check:audio-mode && npm run check:next-action && npm run check:config && npm run check:remote-config && npm run check:content-manifest && npm run check:content-signature && npm run build:check && npm test",
    "ci:release": "npm run ci:fast && npm run check:perf-evidence && npm run perf:budget && npm run quality:gate && npm run check:device-matrix && npm run check:store-forms && npm run check:e2e-device-runs",
    "ci": "npm run ci:fast",
    "e2e:maestro:ci": "maestro test --format junit --output maestro-artifacts/report.xml --test-output-dir maestro-artifacts maestro",
    "lint": "npx eslint .",
    "build:tests": "rm -rf dist-tests && tsc -p tsconfig.tests.json",
    "test:ui": "npm run build:tests && node scripts/run-ui-tests.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:locale-formatting": "node scripts/check-locale-formatting.mjs",
    "perf:budget": "node scripts/perf-budget.mjs",
    "quality:gate": "bash scripts/quality-gate.sh",
    "verify": "npm run ci",
    "verify:smoke": "node scripts/print-smoke-steps.mjs",
    "build:check": "npx expo prebuild --no-install",
    "check:telemetry": "node scripts/check-telemetry-truth.mjs",
    "gen:content-manifest": "node scripts/gen-content-manifest.mjs",
    "gen:content-keys": "node scripts/gen-content-keys.mjs",
    "sign:content-manifest": "node scripts/sign-content-manifest.mjs",
    "check:config": "node scripts/check-config.mjs",
    "check:remote-config": "node scripts/check-remote-config.mjs",
    "check:content-manifest": "node scripts/check-content-manifest.mjs",
    "check:content-signature": "node scripts/check-content-signature.mjs",
    "check:lockfile": "node scripts/check-lockfile.mjs",
    "check:audio-mode": "node scripts/check-audio-mode-ownership.mjs",
    "check:next-action": "node scripts/check-next-action.mjs",
    "check:design-system": "node scripts/audit-design-system.mjs --strict",
    "design-system:audit": "node scripts/audit-design-system.mjs",
    "audit:screens": "node scripts/audit-screen-system.mjs",
    "check:screens": "node scripts/audit-screen-system.mjs --strict",
    "check:perf-evidence": "node scripts/check-perf-evidence.mjs",
    "check:telemetry-pii": "node scripts/check-telemetry-pii.mjs",
    "check:no-todo-core": "node scripts/check-no-todo-core.mjs",
    "e2e:killer-loop": "maestro test maestro/00_killer_loop.yml",
    "check:device-matrix": "node scripts/check-device-matrix.mjs",
    "check:store-forms": "node scripts/check-store-forms.mjs",
    "check:e2e-device-runs": "node scripts/check-e2e-device-runs.mjs",
    "pack:doctor": "node scripts/pack-doctor.mjs",
    "perf:capture": "node scripts/capture-perf-evidence.mjs",
    "evidence:capture": "node scripts/evidence-capture.mjs",
    "tokens:import:figma": "node scripts/import-figma-tokens.mjs",
    "sandbox:smoke": "npm run build:tests && node scripts/sandbox-smoke.mjs",
    "gen:content-index": "node scripts/gen-content-index.mjs",
    "preinstall": "node scripts/check-node.mjs"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.9",
    "@react-navigation/bottom-tabs": "^7.13.0",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.24",
    "@sentry/react-native": "^8.1.0",
    "@shopify/react-native-skia": "2.4.18",
    "@supabase/supabase-js": "^2.49.1",
    "base64-js": "^1.5.1",
    "expo": "~54.0.33",
    "expo-av": "~16.0.0",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.0",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.0",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-media-library": "~18.0.6",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~14.0.0",
    "expo-sharing": "~14.0.0",
    "expo-speech": "~14.0.8",
    "expo-sqlite": "~16.0.0",
    "expo-status-bar": "~3.0.9",
    "expo-stream-audio": "0.1.3",
    "expo-video-thumbnails": "~10.0.8",
    "jszip": "^3.10.1",
    "ntsiniz-audio-route": "file:modules/ntsiniz-audio-route",
    "ntsiniz-voice-dsp": "file:modules/ntsiniz-voice-dsp",
    "ntsiniz-wav-file-writer": "file:modules/ntsiniz-wav-file-writer",
    "react": "19.1.0",
    "react-native": "0.81.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^9.10.4",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "~4.14.0",
    "react-native-svg": "15.13.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-worklets": "~0.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-ondevice-actions": "^10.3.1",
    "@storybook/addon-ondevice-backgrounds": "^10.3.1",
    "@storybook/addon-ondevice-controls": "^10.3.1",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/react-native": "^10.3.1",
    "@storybook/react-native-web-vite": "^10.3.5",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.12",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "detox": "^20.47.0",
    "eslint": "^9.9.0",
    "expo-build-properties": "^55.0.9",
    "jest": "^29.7.0",
    "react-dom": "19.1.0",
    "react-native-web": "^0.21.2",
    "react-test-renderer": "19.1.0",
    "storybook": "^10.3.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.8"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
